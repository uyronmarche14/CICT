{
  "name": "cict",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "prepare": "husky",
    "backend:dev": "pnpm --filter @cict/contracts build && pnpm --filter @cict/backend dev",
    "backend:build": "pnpm --filter @cict/contracts build && pnpm --filter @cict/backend build",
    "backend:lint": "pnpm --filter @cict/contracts build && pnpm --filter @cict/backend lint",
    "backend:typecheck": "pnpm --filter @cict/contracts build && pnpm --filter @cict/backend typecheck",
    "backend:test": "pnpm --filter @cict/contracts build && pnpm --filter @cict/backend test",
    "backend:seed": "pnpm --filter @cict/contracts build && pnpm --filter @cict/backend seed",
    "backend:mongo:up": "pnpm --filter @cict/backend docker:mongo:up",
    "backend:mongo:down": "pnpm --filter @cict/backend docker:mongo:down",
    "web:dev": "pnpm --filter @cict/contracts build && pnpm --filter @cict/web dev",
    "web:build": "pnpm --filter @cict/contracts build && pnpm --filter @cict/web build",
    "web:lint": "pnpm --filter @cict/contracts build && pnpm --filter @cict/web lint",
    "web:typecheck": "pnpm --filter @cict/contracts build && pnpm --filter @cict/web typecheck",
    "web:test": "pnpm --filter @cict/contracts build && pnpm --filter @cict/web test",
    "mobile:dev": "pnpm --filter @cict/contracts build && pnpm --filter @cict/mobile dev",
    "mobile:android": "pnpm --filter @cict/contracts build && pnpm --filter @cict/mobile android",
    "mobile:ios": "pnpm --filter @cict/contracts build && pnpm --filter @cict/mobile ios",
    "mobile:web": "pnpm --filter @cict/contracts build && pnpm --filter @cict/mobile web",
    "mobile:lint": "pnpm --filter @cict/contracts build && pnpm --filter @cict/mobile lint",
    "mobile:typecheck": "pnpm --filter @cict/contracts build && pnpm --filter @cict/mobile typecheck",
    "mobile:test": "pnpm --filter @cict/contracts build && pnpm --filter @cict/mobile test",
    "contracts:build": "pnpm --filter @cict/contracts build",
    "contracts:typecheck": "pnpm --filter @cict/contracts typecheck",
    "contracts:test": "pnpm --filter @cict/contracts test",
    "lint": "pnpm --filter @cict/contracts build && pnpm --filter './apps/**' --if-present lint",
    "typecheck": "pnpm --filter @cict/contracts build && pnpm --filter './packages/**' --if-present typecheck && pnpm --filter './apps/**' --if-present typecheck",
    "test": "pnpm --filter @cict/contracts build && pnpm --filter './packages/**' --if-present test && pnpm --filter './apps/**' --if-present test",
    "build": "pnpm --filter @cict/contracts build && pnpm --filter @cict/backend build && pnpm --filter @cict/web build",
    "backend:tunnel": "bash scripts/mobile-backend-tunnel.sh"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3"
  }
}
