{
  "name": "@cict/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint -- --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "TMPDIR=/tmp jest --passWithNoTests",
    "test:ci": "TMPDIR=/tmp jest --runInBand --passWithNoTests --forceExit",
    "deps:check": "expo install --check",
    "doctor": "pnpm dlx expo-doctor@1.19.10",
    "export:android": "expo export --platform android --output-dir dist",
    "release:check": "pnpm run lint && pnpm run typecheck && pnpm run test:ci && pnpm run deps:check && pnpm run doctor && pnpm run export:android",
    "eas:build:dev": "pnpm run release:check && pnpm dlx eas-cli@20.1.0 build --platform android --profile development",
    "eas:build:preview": "pnpm run release:check && pnpm dlx eas-cli@20.1.0 build --platform android --profile preview",
    "eas:build:prod": "pnpm run release:check && pnpm dlx eas-cli@20.1.0 build --platform android --profile production"
  },
  "dependencies": {
    "@cict/contracts": "workspace:*",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^3.10.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@tanstack/react-query": "^5.90.11",
    "axios": "^1.13.2",
    "expo": "~54.0.35",
    "expo-av": "~16.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "^14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "~19.1.0",
    "react-hook-form": "^7.67.0",
    "react-native": "~0.81.5",
    "react-native-qrcode-svg": "^6.3.16",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "~15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-webview": "~13.15.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@cict/eslint-config": "workspace:*",
    "@cict/tsconfig": "workspace:*",
    "@expo/ngrok": "^4.1.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.17",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "typescript": "^5.9.3"
  }
}
